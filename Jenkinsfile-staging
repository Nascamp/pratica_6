pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Versão da imagem')
    }

    stages {

        stage('Pull da Imagem') {
            steps {
                script {
                    sh "docker pull Darlananan/pratica6:${params.IMAGE_TAG}"
                }
            }
        }

        stage('Subir container Staging') {
            steps {
                sh '''
                    docker rm -f pratica6_staging || true
                    docker run -d --name pratica6_staging -p 8081:8080 Darlananan/pratica6:${IMAGE_TAG}
                '''
            }
        }

        stage('Smoke Test') {
            steps {
                sh "curl -f http://localhost:8081 || exit 1"
            }
        }

    }
}
